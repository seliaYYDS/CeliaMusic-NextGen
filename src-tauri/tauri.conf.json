{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Celia Music Next Gen",
  "version": "0.1.0",
  "identifier": "com.xchzq.celiamusicnextgen",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Celia Music Next Gen",
        "width": 960,
        "height": 600,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "template": "installer-template.nsi",
        "installerIcon": "../icon.ico",
        "sidebarImage": "../sidebar-nsis.bmp",
        "languages": ["SimpChinese"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
